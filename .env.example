# ============================================
# .env.example - 构建时环境变量模板
# ============================================
# 用途：仅用于构建时工具（Vite、Drizzle Kit、Node.js 脚本）
# 这些变量在构建过程中使用，不会注入到 Worker 运行时
#
# 复制此文件为 .env.local 并填入实际值
# .env.local 已在 .gitignore 中，不会被提交
# ============================================

# Cloudflare 配置（用于 Drizzle Kit 远程操作 D1）
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_D1_DATABASE_ID=your_d1_database_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Better Auth URL（构建时配置）
BETTER_AUTH_URL=http://localhost:3000

# OpenAI 配置（构建时使用）
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Gemini 配置（构建时使用）
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.0-flash-exp

# R2 公共域名（构建时配置）
R2_PUBLIC_DOMAIN=your_r2_public_domain.r2.dev
