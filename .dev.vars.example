# ============================================
# .dev.vars - Wrangler 本地开发密钥
# ============================================
# 用途：仅用于 Workers 运行时需要的密钥
# 这些变量在 Worker 中通过 env.VARIABLE_NAME 访问
#
# 复制此文件为 .dev.vars 并填入实际值
# .dev.vars 已在 .gitignore 中，不会被提交
# ============================================

# R2 配置（用于生成预签名 URL）
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# Better Auth Secret（Worker 运行时需要）
BETTER_AUTH_SECRET=your-random-secret-key-here

# OAuth 配置（Worker 运行时需要）
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# AI API Keys（Worker 运行时需要）
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
