# ============================================
# .dev.vars - Unified Local Development Environment Variables
# ============================================
# Purpose:
# 1. Wrangler automatically reads and injects into Worker runtime
# 2. Drizzle Kit reads via dotenv for database operations
# 3. Other Node.js scripts can also read via dotenv
#
# Copy this file to .dev.vars and fill in actual values
# .dev.vars is in .gitignore and will not be committed
# ============================================

# ===== Cloudflare Configuration =====
# Used for Drizzle Kit remote operations on D1 database
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_D1_DATABASE_ID=your_d1_database_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# ===== Better Auth =====
BETTER_AUTH_SECRET=your-random-secret-key-here
BETTER_AUTH_URL=http://localhost:3000

# ===== OAuth Configuration =====
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ===== Review Guest (Optional) =====
# Set to true only when you explicitly want guest review mode in local dev
VITE_ENABLE_REVIEW_GUEST=false

# ===== AI API Keys =====
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.2-instant

GEMINI_API_KEY=your-gemini-api-key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-3.1-flash-image-preview

# ===== Cloudflare AI Gateway (Optional) =====
# If using AI Gateway, change GEMINI_BASE_URL to:
# https://gateway.ai.cloudflare.com/v1/{account_id}/{gateway_id}/openrouter
# or https://gateway.ai.cloudflare.com/v1/{account_id}/{gateway_id}/google-ai-studio
CF_API_TOKEN=your-cloudflare-api-token
